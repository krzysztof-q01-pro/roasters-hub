generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  id            String         @id
  email         String         @unique
  role          UserRole       @default(ROASTER)
  createdAt     DateTime       @default(now())
  adminNotes    AdminNote[]
  savedRoasters SavedRoaster[]
  savedCafes    SavedCafe[]
  ownedRoasters Roaster[]      @relation("RoasterOwner")
  ownedCafes    Cafe[]         @relation("CafeOwner")

  @@map("user_profiles")
}

model Roaster {
  id             String                @id @default(cuid())
  name           String
  slug           String                @unique
  description    String?
  country        String
  countryCode    String
  city           String
  lat            Float?
  lng            Float?
  website        String?
  email          String?
  instagram      String?
  facebook       String?
  shopUrl        String?
  certifications String[]
  origins        String[]
  roastStyles    String[]
  status         RoasterStatus         @default(PENDING)
  featured       Boolean               @default(false)
  featuredUntil  DateTime?
  verifiedAt     DateTime?
  rejectedAt     DateTime?
  rejectedReason       String?
  address              String?
  postalCode           String?
  phone                String?
  foundedYear          Int?
  brewingMethods       String[]
  wholesaleAvailable   Boolean?
  subscriptionAvailable Boolean?
  openingHours         Json?
  hasCafe              Boolean?
  hasTastingRoom       Boolean?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  ownerId              String?
  adminNotes           AdminNote[]
  servedAt             CafeRoasterRelation[]
  events         ProfileEvent[]
  reviews        Review[]
  images         RoasterImage[]
  savedBy        SavedRoaster[]
  owner          UserProfile?          @relation("RoasterOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([country])
  @@index([countryCode])
  @@index([city])
  @@index([featured])
  @@index([status, featured])
  @@index([ownerId])
  @@map("roasters")
}

model RoasterImage {
  id        String  @id @default(cuid())
  roasterId String
  url       String
  alt       String?
  order     Int     @default(0)
  isPrimary Boolean @default(false)
  roaster   Roaster @relation(fields: [roasterId], references: [id], onDelete: Cascade)

  @@index([roasterId])
  @@map("roaster_images")
}

model ProfileEvent {
  id        String    @id @default(cuid())
  roasterId String
  type      EventType
  ipHash    String?
  userAgent String?
  createdAt DateTime  @default(now())
  roaster   Roaster   @relation(fields: [roasterId], references: [id], onDelete: Cascade)

  @@index([roasterId])
  @@index([roasterId, type])
  @@index([createdAt])
  @@map("profile_events")
}

model CafeEvent {
  id        String    @id @default(cuid())
  cafeId    String
  type      EventType
  ipHash    String?
  userAgent String?
  createdAt DateTime  @default(now())
  cafe      Cafe      @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@index([cafeId])
  @@index([cafeId, type])
  @@index([createdAt])
  @@map("cafe_events")
}

model AdminNote {
  id        String      @id @default(cuid())
  roasterId String
  adminId   String
  note      String
  createdAt DateTime    @default(now())
  admin     UserProfile @relation(fields: [adminId], references: [id])
  roaster   Roaster     @relation(fields: [roasterId], references: [id], onDelete: Cascade)

  @@index([roasterId])
  @@map("admin_notes")
}

model NewsletterSubscriber {
  id          String            @id @default(cuid())
  email       String            @unique
  segment     NewsletterSegment @default(CONSUMER)
  confirmedAt DateTime?
  createdAt   DateTime          @default(now())

  @@map("newsletter_subscribers")
}

model Review {
  id         String       @id @default(cuid())
  roasterId  String?
  authorName String
  rating     Int
  comment    String?
  status     ReviewStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  cafeId     String?
  cafe       Cafe?        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  roaster    Roaster?     @relation(fields: [roasterId], references: [id], onDelete: Cascade)

  @@index([roasterId])
  @@index([roasterId, status])
  @@index([cafeId])
  @@index([cafeId, status])
  @@map("reviews")
}

model SavedRoaster {
  id        String      @id @default(cuid())
  userId    String
  roasterId String
  createdAt DateTime    @default(now())
  roaster   Roaster     @relation(fields: [roasterId], references: [id], onDelete: Cascade)
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roasterId])
  @@index([userId])
  @@map("saved_roasters")
}

model SavedCafe {
  id        String      @id @default(cuid())
  userId    String
  cafeId    String
  createdAt DateTime    @default(now())
  cafe      Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cafeId])
  @@index([userId])
  @@map("saved_cafes")
}

model Cafe {
  id             String                @id @default(cuid())
  name           String
  slug           String                @unique
  description    String?
  country        String
  countryCode    String
  city           String
  address        String?
  lat            Float?
  lng            Float?
  website        String?
  instagram      String?
  phone          String?
  logoUrl        String?
  coverImageUrl  String?
  status         CafeStatus            @default(PENDING)
  featured       Boolean               @default(false)
  verifiedAt     DateTime?
  rejectedAt      DateTime?
  rejectedReason  String?
  postalCode      String?
  email           String?
  priceRange      String?
  seatingCapacity Int?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  ownerId         String?
  sourceUrl       String?
  openingHours    String?
  serving        String[]              @default([])
  services       String[]              @default([])
  roasters       CafeRoasterRelation[]
  reviews        Review[]
  savedBy        SavedCafe[]
  events         CafeEvent[]
  owner          UserProfile?          @relation("CafeOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([country])
  @@index([city])
  @@index([serving], type: Gin)
  @@index([services], type: Gin)
  @@index([ownerId])
  @@map("cafes")
}

model CafeRoasterRelation {
  id        String   @id @default(cuid())
  cafeId    String
  roasterId String
  createdAt DateTime @default(now())
  cafe      Cafe     @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  roaster   Roaster  @relation(fields: [roasterId], references: [id], onDelete: Cascade)

  @@unique([cafeId, roasterId])
  @@index([cafeId])
  @@index([roasterId])
  @@map("cafe_roaster_relations")
}

model ApiKey {
  id        String    @id @default(cuid())
  name      String
  key       String    @unique
  createdAt DateTime  @default(now())
  lastUsed  DateTime?
  active    Boolean   @default(true)

  @@map("api_keys")
}

model EnrichmentRun {
  id          String               @id @default(cuid())
  entityType  String
  query       Json
  sources     String[]
  status      EnrichmentRunStatus  @default(RUNNING)
  stats       Json                 @default("{}")
  proposals   EnrichmentProposal[]
  createdAt   DateTime             @default(now())
  completedAt DateTime?

  @@map("enrichment_runs")
}

model EnrichmentProposal {
  id            String        @id @default(cuid())
  runId         String
  run           EnrichmentRun @relation(fields: [runId], references: [id])
  entityType    String
  entityId      String?
  entityName    String
  changeType    String
  fieldKey      String
  fieldGroup    String
  fieldPriority String
  currentValue  Json?
  proposedValue Json
  confidence    Float
  sourceId      String
  sourceUrl     String?
  status        EnrichmentProposalStatus  @default(PENDING)
  reviewedAt    DateTime?
  reviewedBy    String?
  createdAt     DateTime      @default(now())

  @@index([runId])
  @@index([entityId])
  @@index([status])
  @@map("enrichment_proposals")
}

enum RoasterStatus {
  PENDING
  VERIFIED
  REJECTED
  INACTIVE
}

enum UserRole {
  ROASTER
  ADMIN
  CAFE
}

enum EventType {
  PAGE_VIEW
  CONTACT_CLICK
  SHOP_CLICK
  WEBSITE_CLICK
  MAP_CLICK
  SHARE_CLICK
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CafeStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum NewsletterSegment {
  CAFE
  CONSUMER
  ROASTER
}

enum EnrichmentRunStatus {
  RUNNING
  DONE
  FAILED
}

enum EnrichmentProposalStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}
