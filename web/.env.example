# Roasters Hub — Environment Variables
# Copy this file to .env.local and fill in the values.

# ─── Database (Vercel Postgres / Neon) ──────────────────────────────────────
# Found in: Vercel Dashboard → Storage → your database → .env.local tab
# Or: Neon Console → Connection Details
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Auth (Clerk) ───────────────────────────────────────────────────────────
# Found in: https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# Clerk routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Found in: https://resend.com/api-keys
# Used for: registration confirmation, verify/reject notifications, newsletter
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="Bean Map <noreply@beanmap.cafe>"

# ─── File Upload (Uploadthing) — Phase 2 ───────────────────────────────────
# Found in: https://uploadthing.com/dashboard → your app → API Keys
# UPLOADTHING_TOKEN="eyJ..."

# ─── Analytics (Plausible) — Phase 2 ─────────────────────────────────────────
# Set to your domain to enable Plausible analytics (e.g. "beanmap.cafe")
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# ─── MCP Tools ──────────────────────────────────────────────────────────────
# Context7 — dokumentacja bibliotek dla agentów/Claude Code
# Pobierz klucz: https://context7.com → zaloguj się → API Keys
# CONTEXT7_API_KEY="ctx7sk-cd5b4514-ebfa-4890-b4c3-5a8f30e75611"

# ─── App ─────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
