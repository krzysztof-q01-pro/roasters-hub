# Roasters Hub — Environment Variables
# Copy this file to .env.local and fill in the values.

# ─── Database (Vercel Postgres / Neon) ──────────────────────────────────────
# Found in: Vercel Dashboard → Storage → your database → .env.local tab
# Or: Neon Console → Connection Details
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Auth (Clerk) ───────────────────────────────────────────────────────────
# Found in: https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# Clerk routes (optional — defaults shown)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
# NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ─── Email (Resend) — Phase 2 ───────────────────────────────────────────────
# RESEND_API_KEY="re_..."

# ─── App ─────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Preview Auth (temporary — remove after Clerk is set up) ────────────────
# AUTH_USER="admin"
# AUTH_PASSWORD="your-preview-password"
