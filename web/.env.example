# Roasters Hub — Environment Variables
# Copy this file to .env.local and fill in the values.
# Get Supabase credentials from: https://app.supabase.com → Project Settings

# ─── Database (Prisma) ────────────────────────────────────────────────────────
# Connection pooler URL (for queries in production/preview)
# Found in: Project Settings → Database → Connection string → Transaction mode
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct URL (for migrations only)
# Found in: Project Settings → Database → Connection string → Session mode
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── Supabase Auth & Storage ──────────────────────────────────────────────────
# Found in: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Service role key — server-side only, NEVER expose to browser
# Found in: Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─── Preview Auth (temporary — remove after Supabase Auth is set up) ──────────
# Uncomment to enable Basic HTTP Auth on the preview deploy
# AUTH_USER="admin"
# AUTH_PASSWORD="your-preview-password"
